#ifndef _UTILITY_RUL_
#define _UTILITY_RUL_  

function BOOL IsGroupServiceAccount(svUser)
	NUMBER nUserLength;
	STRING szSubStr;
begin
	nUserLength = StrLength(svUser);
	if(nUserLength > 0) then			
		if(StrSub(szSubStr, svUser, nUserLength - 1, 1) = 1) then
			if(szSubStr = "$") then					
				return TRUE;																																					
			endif;
		endif;
	endif;	
	return FALSE;
end;

function AddDCOMProtocolTCPIP()
	STRING szKey, svName, svData, svValue, svString;
	NUMBER nvSize, nvType, nResult;
	LIST dcomList;
	BOOL bFound;
begin
	szKey = "SOFTWARE\\Microsoft\\Rpc";
	svName = "DCOM Protocols";
	svData = "ncacn_ip_tcp";
	bFound = FALSE;
	if(!AddStringToRegMultiSZ(HKEY_LOCAL_MACHINE,szKey, svName, svData, FALSE)) then
		WriteLog("AddDCOMProtocolTCPIP: Failed to set " + szKey ^ svName);	
	endif;
end;

function BOOL AddTCPIPPortRange()
	STRING svPropertyValue, szKey, svName, svData;
	NUMBER nvBufferSize;
begin
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);	
	szKey = "SOFTWARE\\Microsoft\\Rpc\\Internet";
	if(RegDBKeyExist(szKey) < 0) then
		svName = "PortsInternetAvailable";
		svData = "N";
		if(RegDBSetKeyValueEx(szKey, svName, REGDB_STRING, svData, -1) < 0) then
			WriteLog("AddTCPIPPortRange: Failed to set " + szKey ^ svName);
		endif;
		svName = "UseInternetPorts";
		svData = "N";
		if(RegDBSetKeyValueEx(szKey, svName, REGDB_STRING, svData, -1) < 0) then
			WriteLog("AddTCPIPPortRange: Failed to set " + szKey ^ svName);
		endif;
	endif;
	
	nvBufferSize = MAX_PATH;
	MsiGetProperty(ISMSI_HANDLE, "PAR_PORT_RANGE", svPropertyValue, nvBufferSize);
	szKey = "SOFTWARE\\Microsoft\\Rpc\\Internet";
	svName = "Ports";
	svData = svPropertyValue;
	if(!AddStringToRegMultiSZ(HKEY_LOCAL_MACHINE, szKey, svName, svData, FALSE)) then
		WriteLog("AddTCPIPPortRange: Failed to set " + szKey ^ svName);	
		return FALSE;
	endif;
	return TRUE;
end;

function SetNetTCPPortSharing()
	STRING szRegValue, szParam;
	NUMBER nvExitCode, nvRegType, nvRegValueSize;
begin
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);	
  	//detect if Net.Tcp Port Sharing Service is enabled.
    if( RegDBGetKeyValueEx("\\SYSTEM\\ControlSet001\\Services\\NetTcpPortSharing", "Start", nvRegType, szRegValue, nvRegValueSize) = 0) then // In registry
		if(szRegValue == "4") then //4 represents Disabled
			if(AskYesNo("The Net.Tcp Port Sharing Service must be enabled before continuing. Click 'Yes' to enable the service. Clicking 'No' will cancel the setup.", YES) = YES) then
				szParam = "config NetTcpPortSharing start= auto";
				if (_LaunchAppEx(SystemFolder ^ "SC.exe", szParam, WAIT,SW_HIDE, -1, nvExitCode) < 0) then 
					WriteErrorToLog(nvExitCode, "Error enabling Net.Tcp Port Sharing Service.");
				endif; 				
			else
				abort;
			endif; 
		endif;
	endif;	
end; 

function EnableWebServerRole()
	STRING szParam, szTemp, szCommand, szCoreWebEngine, szNetFxExtensibility, szNetFxExtensibility45;
	NUMBER nvRegType, nvRegValueSize;
begin
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);	
	RegDBGetKeyValueEx("\\SOFTWARE\\Microsoft\\InetStp\\Components", "CoreWebEngine", nvRegType, szCoreWebEngine, nvRegValueSize); // In registry		
	RegDBGetKeyValueEx("\\SOFTWARE\\Microsoft\\InetStp\\Components", "NetFxExtensibility", nvRegType, szNetFxExtensibility, nvRegValueSize);		
	RegDBGetKeyValueEx("\\SOFTWARE\\Microsoft\\InetStp\\Components", "NetFxExtensibility45", nvRegType, szNetFxExtensibility45, nvRegValueSize);	
	if (GetEnvVar ("WINDIR", szTemp) >= 0) then
		Disable(WOW64FSREDIRECTION);
		WriteLog("EnableWebServerRole Start" );	 
		Delay(1);
		szCommand = szTemp^"System32\\DISM.exe";		
		//check to see if necessary		
		if(SYSINFO.nISOSL = ISOSL_WINVISTA_SERVER2008) then
			if(szCoreWebEngine != "1" && szNetFxExtensibility != "1") then
				szParam = "/online /enable-feature /featurename:IIS-WebServerRole /featurename:IIS-WebServer /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);					
				
				szParam = "/online /enable-feature /featurename:IIS-CommonHttpFeatures /featurename:IIS-StaticContent /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	

				szParam = "/online /enable-feature /featurename:IIS-DefaultDocument /featurename:IIS-DirectoryBrowsing /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
								
				szParam = "/online /enable-feature /featurename:IIS-HttpErrors /featurename:IIS-HttpRedirect /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
					
				szParam = "/online /enable-feature /featurename:IIS-ApplicationDevelopment /featurename:IIS-ASP /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
					
				szParam = "/online /enable-feature /featurename:IIS-CGI /featurename:IIS-ISAPIExtensions /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
					
				szParam = "/online /enable-feature /featurename:IIS-ISAPIFilter /featurename:IIS-ServerSideIncludes /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
					
				szParam = "/online /enable-feature /featurename:IIS-HealthAndDiagnostics /featurename:IIS-HttpLogging /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
					
				szParam = "/online /enable-feature /featurename:IIS-LoggingLibraries /featurename:IIS-RequestMonitor /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
								
				szParam = "/online /enable-feature /featurename:IIS-HttpTracing /featurename:IIS-CustomLogging /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
								
				szParam = "/online /enable-feature /featurename:IIS-ODBCLogging /featurename:IIS-Security /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);				
					
				szParam = "/online /enable-feature /featurename:IIS-BasicAuthentication /featurename:IIS-WindowsAuthentication /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);				
					
				szParam = "/online /enable-feature /featurename:IIS-DigestAuthentication /featurename:IIS-ClientCertificateMappingAuthentication /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
								
				szParam = "/online /enable-feature /featurename:IIS-IISCertificateMappingAuthentication /featurename:IIS-URLAuthorization /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
								
				szParam = "/online /enable-feature /featurename:IIS-RequestFiltering /featurename:IIS-IPSecurity /featurename:IIS-Performance /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);				
					
				szParam = "/online /enable-feature /featurename:IIS-HttpCompressionStatic /featurename:IIS-HttpCompressionDynamic /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
								
				szParam = "/online /enable-feature /featurename:IIS-WebServerManagementTools /featurename:IIS-ManagementConsole /featurename:IIS-ManagementService /featurename:IIS-ManagementScriptingTools /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
					
				szParam = "/online /enable-feature /featurename:IIS-IIS6ManagementCompatibility /featurename:IIS-Metabase /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
								
				szParam = "/online /enable-feature /featurename:IIS-WMICompatibility /featurename:IIS-LegacyScripts /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
								
				szParam = "/online /enable-feature /featurename:IIS-FTPPublishingService /featurename:IIS-FTPServer /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	

				szParam = "/online /enable-feature /featurename:IIS-NetFxExtensibility /featurename:IIS-ASPNET /Quiet /NoRestart";
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);				
								
				szParam = "/online /enable-feature /featurename:WAS-WindowsActivationService /featurename:WCF-HTTP-Activation /featurename:WAS-ProcessModel /NoRestart";		
				WriteLog(szCommand + " " + szParam);	    
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);				
			else
				WriteLog("Skipping enabling of Web Server Role: Already enabled." );	
			endif;
		else
			if(szCoreWebEngine != "1" && szNetFxExtensibility45 != "1") then
				//windows 2012+
				szParam = "/online /enable-feature /all /featurename:IIS-WebServerRole /featurename:IIS-ASPNET45 /NoRestart";
				WriteLog(szCommand + " " + szParam);	 		
				LaunchAppAndWait(szCommand, szParam, LAAW_OPTION_WAIT);					
			else
				WriteLog("Skipping enabling of Web Server Role: Already enabled." );			
			endif;
		endif;
		WriteLog("EnableWebServerRole End");	
		Enable(WOW64FSREDIRECTION); 			
	endif;
end;

function AddUserToLocalGroupEx(szGroup, szUser)
	STRING szParam;
begin;
	szParam = " localgroup " + szGroup + " " + szUser + " /add ";	
	LaunchAppAndWait(WIN_NET_COMMAND, szParam, LAAW_OPTION_WAIT|LAAW_OPTION_HIDDEN);	
end;

function DisableForceUnloadPolicy()
	STRING szKey, szName, svValue;
	NUMBER nvSize, nvType, nvValue;
begin
	szKey = "SOFTWARE\\Policies\\Microsoft\\Windows\\System";
	szName = "DisableForceUnload";
	EnableSystemRegistrySetting(szKey, szName);
end;

