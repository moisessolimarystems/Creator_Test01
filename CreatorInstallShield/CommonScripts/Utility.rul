function RegAsmRegister(svRegAsmPath, svFilePath, bHasTypeLib)
	STRING szCmdLine;
	NUMBER nvExitCode;
begin
	LongPathToQuote(svFilePath,TRUE);  
	if(bHasTypeLib) then
		szCmdLine = " /tlb /codebase " + svFilePath;
	else
		szCmdLine = " /codebase " + svFilePath;
	endif; 	    
	if(Is(FILE_EXISTS, svFilePath)) then      
	   WriteLog("RegAsm Register Start: " + svFilePath);     
	   if (_LaunchAppEx(svRegAsmPath,
	 	 				szCmdLine , 
	  	 				WAIT, 
	   					SW_HIDE, 
	   					-1, 
	   					nvExitCode) < 0) then 
	       WriteErrorToLog(nvExitCode, "Error registering " + svFilePath);    
	   endif;
	   WriteLog("RegAsm Register End: " + svFilePath);	
	else
		WriteLog("Skipping RegAsmRegister: " + svFilePath + " not found.");		   
	endif;	
end;   

function RegAsmUnRegister(svRegAsmPath, svFilePath, bHasTypeLib)
	STRING svCmdLine;
	NUMBER nvExitCode;
begin 
	LongPathToQuote(svFilePath,TRUE); 	
	if(bHasTypeLib) then		
		svCmdLine = "/unregister /tlb /codebase " + svFilePath;
	else
		svCmdLine = "/unregister /codebase " + svFilePath;
	endif;

	if(Is(FILE_EXISTS, svFilePath)) then 	
	   WriteLog("RegAsm UnRegister Start: " + svFilePath);	         	
		if (_LaunchAppEx(svRegAsmPath,
						 svCmdLine , 
						 WAIT, 
						 SW_HIDE, 
						 -1, 
					 	nvExitCode) < 0) then 
			WriteErrorToLog(nvExitCode, "Error unregistering " + svFilePath);		
		endif;  
		WriteLog("RegAsm UnRegister Start: " + svFilePath);	
	else
		WriteLog("Skipping RegAsmUnRegister: " + svFilePath + " not found.");		 	
	endif; 
end;

function RegSvcsRegister(svRegSvcsPath, svFilePath, svAppName)
	STRING szCmdLine, svErrorMessage;
	NUMBER nvExitCode;
begin    
	LongPathToQuote(svFilePath,TRUE);     
	Sprintf(szCmdLine, " /appname:\"%s\" /noreconfig %s", svAppName, svFilePath);    
	if(Is(FILE_EXISTS, svFilePath)) then      
	   WriteLog("RegSvcs Register Start: " + svFilePath);     
	   if (_LaunchAppEx(svRegSvcsPath,
	 	 				szCmdLine , 
	  	 				WAIT, 
	   					SW_HIDE, 
	   					-1, 
	   					nvExitCode) < 0) then 
   			svErrorMessage = "Error registering " + svAppName + " as a COM+ Application";
  			WriteErrorToLog(nvExitCode, svErrorMessage);  
   			MessageBox(svErrorMessage, SEVERE);  		
   		endif;  
	   WriteLog("RegSvcs Register End: " + svFilePath);	
	else
		WriteLog("Skipping RegSvcsRegister: " + svFilePath + " not found.");			   
	endif;	
end;   

function RegSvcsUnRegister(svRegSvcsPath, svFilePath, svAppName)
	STRING szCmdLine, svErrorMessage ;
	NUMBER nvExitCode;
begin               
	LongPathToQuote(svFilePath,TRUE);     
	Sprintf(szCmdLine, " /u /quiet /appname:\"%s\" %s", svAppName, svFilePath);    
	if(Is(FILE_EXISTS, svFilePath)) then      
	   WriteLog("RegSvcs UnRegister Start: " + svFilePath);     
	   if (_LaunchAppEx(svRegSvcsPath,
	 	 				szCmdLine , 
	  	 				WAIT, 
	   					SW_HIDE, 
	   					-1, 
	   					nvExitCode) < 0) then 
   			svErrorMessage = "Error unregistering " + svAppName + " as a COM+ Application";
  			WriteErrorToLog(nvExitCode, svErrorMessage);  
   			MessageBox(svErrorMessage, SEVERE);  		
   		endif;  
	   WriteLog("RegSvcs UnRegister End: " + svFilePath);	
	else
		WriteLog("Skipping RegSvcsUnRegister: " + svFilePath + " not found.");		   
	endif;	
end;         

//============================================================================= 
//
//  Function:   FindReplaceAllFiles
//  Purpose:    replaces all patterns found in a file with a new pattern within a 
//				directory. Includes sub-directories.
//  Parameters:	STRING fileDir   		- fileDirectory to be edited
//				STRING fileName			- filename to edit
//				STRING p_patternToFind	- pattern to be replaced
//				STRING p_newData		- data to replace pattern
//  Returns:	None
//
//=============================================================================
function FindReplaceAllFiles(szFilePath, szFileName, szPattern, szReplace)
	STRING file, filePath, fileName;  
	NUMBER nResult;
begin
	nResult = FindAllFiles(szFilePath, szFileName, file, RESET);
	if(nResult = 0) then 		
		while(nResult = 0) 
			ParsePath(filePath, file, PATH);   
			ParsePath(fileName, file, FILENAME);
			FindNReplaceInFile(filePath, fileName, szPattern, szReplace); 			
			nResult = FindAllFiles(szFilePath, szFileName, file, CONTINUE);        		
    	endwhile;		
	endif; 	                             
end;

//============================================================================= 
//
//  Function:   FindNReplaceInFile
//  Purpose:    replaces a pattern found in a file with a new pattern.
//  Parameters:	STRING fileDir   		- fileDirectory to be edited
//				STRING fileName			- filename to edit
//				STRING p_patternToFind	- pattern to be replaced
//				STRING p_newData		- data to replace pattern
//  Returns:	None
//
//=============================================================================
function FindNReplaceInFile(szFileDir, szFileName, szPatternToFind, szNewData)  
	NUMBER  nvReadFileHandle, nvWriteFileHandle, nLocationInString;
	NUMBER  nvAttribute;
    STRING 	svLine, szLeft, szRight, szTempFileName, svResult;
begin

	if( szPatternToFind = szNewData) goto EndFunction_FindNReplaceInFile;

    // Set the file mode to append.
    OpenFileMode (FILE_MODE_APPEND);

	szTempFileName = "temp.temp";     
    // Open file and leave it open.
    if (CreateFile (nvWriteFileHandle, szFileDir, szTempFileName) < 0) then
        // Report the error.
        MessageBox ("Creating " + szFileDir ^ szTempFileName + " failed.", SEVERE);
        goto EndFunction_FindNReplaceInFile;
	endif;
	    
    // Set the file mode to normal.
    OpenFileMode (FILE_MODE_NORMAL);
    
    // Open the file for editing.
    if(OpenFile (nvReadFileHandle, szFileDir, szFileName) < 0) then
    	WriteLog("Failed to open :" + szFileDir ^ szFileName);
    endif;
	
	
	// Go through entire file
    while (GetLine (nvReadFileHandle, svLine) == 0)
 		while (StrFind(svLine, szPatternToFind) > -1)	//Found Pattern in line
            nLocationInString = StrFind(svLine, szPatternToFind);
            StrSub (szLeft, svLine, 0, nLocationInString);
            StrSub (szRight, svLine, nLocationInString+StrLengthChars(szPatternToFind), StrLengthChars(svLine)-(nLocationInString+StrLengthChars(szPatternToFind)));
            svLine = szLeft + szNewData + szRight;
        endwhile;
    	WriteLine(nvWriteFileHandle, svLine);
    endwhile;
    
    // Close the file.
    CloseFile (nvReadFileHandle);
    
    // Close the file.
    CloseFile (nvWriteFileHandle);
 	
 	//Readonly attrib must be off before delete.
	if Is(FILE_WRITEABLE, szFileDir ^ szFileName) = 0 then
		GetFileInfo (szFileDir ^ szFileName, FILE_ATTRIBUTE, nvAttribute, svResult);
		nvAttribute = nvAttribute & (~FILE_ATTR_READONLY);
		SetFileInfo (szFileDir ^ szFileName, FILE_ATTRIBUTE, nvAttribute, "");
	endif;
	
	//replace old file with new file 	
 	if(DeleteFile (szFileDir ^ szFileName) < 0) then
 		 WriteLog("Failed to delete :" + szFileDir ^ szFileName);
 	endif;
    if(RenameFile (szFileDir ^ szTempFileName ,szFileDir ^ szFileName) < 0) then
    	 WriteLog("Failed to rename :" + szFileDir ^ szTempFileName + " to " + szFileDir ^ szFileName);
    endif;
     
	EndFunction_FindNReplaceInFile:
	
	svLine = "End";
end;
              
function EnableSystemRegistrySetting(szKey, szName)
	STRING svValue;
	NUMBER nvSize, nvType, nvValue;
	BOOL bEnabled;
begin
	bEnabled = FALSE;
	RegDBSetDefaultRoot (HKEY_LOCAL_MACHINE);
	Disable(LOGGING);	
	if(RegDBGetKeyValueEx(szKey,  szName, nvType, svValue, nvSize) = 0) then 
		StrToNum(nvValue, svValue);
		if(nvValue = 1) then //0 means Remote Access is disabled for COMPlus
		    bEnabled = TRUE;  
		    WriteLog("Skipping enabling of " + szKey + "\\" + szName + ": Already set." );	                                                      				
		endif;
	endif;
	if(!bEnabled) then
		WriteLog("Enabling " + szKey + "\\" + szName + "." );		
		svValue = "1";			
		if(RegDBSetKeyValueEx(szKey, szName, REGDB_NUMBER, svValue, -1 ) < 0) then
			WriteLog("Failed to enable: " + szKey + "\\" + szName + "." );	
		endif; 			
	endif; 
		
	if(SYSINFO.bIsWow64) then		
		bEnabled = FALSE;	
		REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY; 	  	
		if(RegDBGetKeyValueEx(szKey,  szName, nvType, svValue, nvSize) = 0) then 
			StrToNum(nvValue, svValue);
			if(nvValue = 1) then //0 means Remote Access is disabled for COMPlus
				bEnabled = TRUE;                                                        				
				WriteLog("Skipping enabling of " + szKey + "\\" + szName + ": Already set." );				
			endif;
		endif;
		if(!bEnabled) then
			WriteLog("Enabling " + szKey + "\\" + szName + "." );			
			svValue = "1";						
			if(RegDBSetKeyValueEx(szKey, szName, REGDB_NUMBER, svValue, -1 ) < 0) then
				WriteLog("Failed to enable: " + szKey + "\\" + szName + "." );	
			endif; 				
		endif; 	
		REGDB_OPTIONS = REGDB_OPTIONS & ~REGDB_OPTION_WOW64_64KEY;			
	endif;  
	Enable(LOGGING);	
end; 

function BOOL AddStringToRegMultiSZ(nDefaultRoot, szRegistryKey, szRegistryValue, szString, bAllowDuplicates)
	LIST	listStrings;
	NUMBER	nType;
	NUMBER	nvCurrentStringSize;
	NUMBER	nvReturnCode;
	NUMBER	nvResultCode;
	NUMBER	nvNewStringSize;
	NUMBER  nResult;
	STRING	svCurrentStringValue;
	STRING	szUpdatedStringValue[32000]; // I hate magic numbers, but I don't know the max size of a REG_MULTI_SZ value.
	STRING	szTemp[32000];
	STRING  svFoundString;
begin
	Disable(LOGGING);
	nType = REGDB_STRING_MULTI;
	listStrings = ListCreate(STRINGLIST);
	nvCurrentStringSize = 0;
	nvReturnCode = 0;
	
	RegDBSetDefaultRoot(nDefaultRoot);
	nvReturnCode = RegDBGetKeyValueEx(szRegistryKey, szRegistryValue, nType, svCurrentStringValue, nvCurrentStringSize); 	
	if (nvReturnCode = 0) then 
		if (nvCurrentStringSize > 0) then
			// Get current strings from value
			nvReturnCode = StrGetTokens(listStrings, svCurrentStringValue, ""); 
			if (nvReturnCode != 0) then
				WriteLog("AddStringToRegMultiSZ(): StrGetTokens() returned an error: " + FormatMessage(nvReturnCode));
				ListDestroy(listStrings);
				return FALSE;
			endif;
			
			if(!bAllowDuplicates) then
				nResult = ListGetFirstString(listStrings, svFoundString);		
				while(nResult != END_OF_LIST) 
					if(svFoundString = szString) then
						WriteLog("AddStringToRegMultiSZ(): " + szString + " already exists. Skip adding of " + szString);
						ListDestroy(listStrings);
						return FALSE;
					endif;
					nResult = ListGetNextString(listStrings, svFoundString);
				endwhile;
			endif;			

			// Add our string to the list of strings
			nvReturnCode = ListAddString(listStrings, szString, AFTER);
			if (nvReturnCode < ISERR_SUCCESS) then
				WriteLog("AddStringToRegMultiSZ(): ListAddString() returned an error: " + FormatMessage(nvReturnCode));
				ListDestroy(listStrings);
				return FALSE;
			endif;
		endif;
	else 	// registry value does not exist, create our own
			nvReturnCode = ListAddString(listStrings, szString, AFTER);
			if (nvReturnCode < ISERR_SUCCESS) then
				WriteLog("AddStringToRegMultiSZ(): ListAddString() returned an error: " + FormatMessage(nvReturnCode));
				ListDestroy(listStrings);
				return FALSE;
			endif;
	endif; 

	// Prepare the string as a multi string registry value
	nvReturnCode = StrPutTokens(listStrings, szUpdatedStringValue, "", TRUE);
	if (nvReturnCode != 0) then
		WriteLog("AddStringToRegMultiSZ(): StrPutTokens() returned an error: " + FormatMessage(nvReturnCode));
		ListDestroy(listStrings);
		return FALSE;
	endif;
	
	// Get size of null delimited string
	szTemp = szUpdatedStringValue;
	CharReplace(szTemp, STRTOCHAR('\0'), STRTOCHAR('|'), 0);
	nvNewStringSize = StrLengthChars(szTemp);
	
	// Update registry value with new strings 
	nvReturnCode = RegDBSetKeyValueEx(szRegistryKey, szRegistryValue, nType, szUpdatedStringValue, (nvNewStringSize + 2)); // add two for the two null chars at the end
	if (nvReturnCode != 0) then
		WriteLog("AddStringToRegMultiSZ(): RegDBSetKeyValueEx() returned an error: " + FormatMessage(nvReturnCode));
		ListDestroy(listStrings);
		return FALSE;
	endif;

	ListDestroy(listStrings);
	Enable(LOGGING);
	
	return TRUE;
end;

function BOOL RemoveStringFromRegMultiSZ(nDefaultRoot, szRegistryKey, szRegistryValue, szString)
	LIST	listStrings;
	NUMBER	nType;
	NUMBER	nvCurrentStringSize;
	NUMBER	nvReturnCode;
	NUMBER	nvResultCode;
	NUMBER	nvNewStringSize;
	NUMBER	nvListCount;
	STRING	svCurrentStringValue;
	STRING	szUpdatedStringValue[32000]; // I hate magic numbers, but I don't know the max size of a REG_MULTI_SZ value.
	STRING	svListString;
	STRING	svCurrentListString;
	STRING	szTemp[32000];
begin
	Disable(LOGGING);
	nType = REGDB_STRING_MULTI;
	listStrings = ListCreate(STRINGLIST);
	nvCurrentStringSize = 0;
	nvReturnCode = 0;
	
	RegDBSetDefaultRoot(nDefaultRoot);
	nvReturnCode = RegDBGetKeyValueEx(szRegistryKey, szRegistryValue, nType, svCurrentStringValue, nvCurrentStringSize); 	
	if (nvReturnCode = 0) then 
		if (nvCurrentStringSize > 0) then
			// Get current strings from value
			nvReturnCode = StrGetTokens(listStrings, svCurrentStringValue, ""); 
			if (nvReturnCode != 0) then
				WriteLog("RemoveStringFromRegMultiSZ(): StrGetTokens() returned an error: " + FormatMessage(nvReturnCode));
				ListDestroy(listStrings);
				return FALSE;
			endif;
			nvListCount = ListCount(listStrings);
			
			// iterate through list of strings, deleting ones matching the incoming szString.
			nvResultCode = ListGetFirstString(listStrings, svListString);
			while (nvResultCode != END_OF_LIST)
				ListCurrentString(listStrings, svCurrentListString); 
				if (StrCompare(svCurrentListString, szString) = 0) then // strings are the same
					nvReturnCode = ListDeleteString(listStrings);
					if (nvReturnCode != 0) then
						WriteLog("RemoveStringFromRegMultiSZ(): ListDeleteString() returned an error: " + FormatMessage(nvReturnCode));
						ListDestroy(listStrings);
						return FALSE;
					endif;
				endif;
				nvResultCode = ListGetNextString(listStrings, svListString);
			endwhile;
            nvListCount = ListCount(listStrings);
			// Prepare the string as a multi string registry value
			nvReturnCode = StrPutTokens(listStrings, szUpdatedStringValue, "", TRUE);
			if (nvReturnCode != 0) then
				WriteLog("RemoveStringFromRegMultiSZ(): StrPutTokens() returned an error: " + FormatMessage(nvReturnCode));
				ListDestroy(listStrings);
				return FALSE;
			endif;
			
			// Get size of null delimited string
			szTemp = szUpdatedStringValue;
			CharReplace(szTemp, STRTOCHAR('\0'), STRTOCHAR('|'), 0);
			nvNewStringSize = StrLengthChars(szTemp);
			
			// Update registry value with new strings 
			nvReturnCode = RegDBSetKeyValueEx(szRegistryKey, szRegistryValue, nType, szUpdatedStringValue, (nvNewStringSize + 2)); // add two for the two null chars at the end
			if (nvReturnCode != 0) then
				WriteLog("RemoveStringFromRegMultiSZ(): RegDBSetKeyValueEx() returned an error: " + FormatMessage(nvReturnCode));
				ListDestroy(listStrings);
				return FALSE;
			endif;
		endif;
    else
    	WriteLog("RemoveStringFromRegMultiSZ(): Unable to read current values from registry value. Error: " + FormatMessage(nvReturnCode));
    	return FALSE;
	endif;
	
	ListDestroy(listStrings);
	Enable(LOGGING); 
	
	return TRUE;
end;              
              
#endif //_UTILITY_RUL_
  