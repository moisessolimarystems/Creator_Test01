//===== OS Type Structure =====
typedef OSTYPE
begin
    BOOL IsWindowsXP;
    BOOL IsWindowsME;
    BOOL IsWindows2000;
    BOOL IsWindows2000Workstation;
    BOOL IsWindows2000Server;
    BOOL IsWindowsNT4;
    BOOL IsWindowsNT351;
    BOOL IsWindows98;
    BOOL IsWindows95;            
end;                           

//===== UNINSTALL Type Structure =====
typedef UNINSTALLTYPE
begin
    BOOL AddRemove;
    BOOL Program;
end;  

    // your script function prototypes
    //prototype CreateODBC_SQLCreatorKey(); 
    prototype SetupFolders();
    prototype CheckRequirements(); 
    prototype InstallLicensing(); 
    prototype InstallSentinelDriver();
    prototype InstallDotNet();
    
    // your global variables   
    BOOL        	bIsShellExplorer;
    STRING			szCmdLine;
    VARIANT			vDllString;   
    OSTYPE			gstructOSTYPE;
    UNINSTALLTYPE 	gstructUNINSTALLTYPE;


//////////////////////////////////////////////////////////////////////////////
//                                                                           
//  FUNCTION:   SetupFolders                                            
//                                                                           
//  EVENT:      Add folder to the desktop
//                                                                           
///////////////////////////////////////////////////////////////////////////////
function SetupFolders() 
    STRING svPath, svIconPath;
begin
	//Add Solimar.exe to desktop
    svPath = TARGETDIR ^ "CreatorProject.exe";
    svIconPath = TARGETDIR ^ "tree.ico";
    LongPathToQuote ( svPath , TRUE );
    AddFolderIcon ( FOLDER_DESKTOP, "Creator" , svPath , TARGETDIR , svIconPath , 0 , "" , REPLACE );	
	CreateDir(TARGETDIR ^ "Password Packets");
end; 

