Class CReportAccess
 
    Public mBuild, mConnection, mCmdTemp
    Public mLargestArchSoFar, mArchOffset

'=======================================================================
' function     : Class_Initialize()
' parameters    : none
' description  : initializes class by creating ADO Database connection
'                object.
'
'=======================================================================
    Public Sub Class_Initialize() 'set default values
        mLargestArchSoFar = ""
        mArchOffset = ""
        Set mConnection = wscript.CreateObject("ADODB.Connection")
        CurRevNum = ""
    End Sub

'=======================================================================
' function     : Class_Terminate()
' parameters    : none
' description  : Cleans up class by deleting created access table
'                
'
'=======================================================================
    Private Sub Class_Terminate()
	mConnection.Close
	mBuild.FSO.DeleteFile "E:\accessDB\" & mBuild.ProductChoice & "db1.mdb", True
    End Sub

'=======================================================================
' function     : Set Build
' parameters   : ByRef aBuild - reference to build class object
' description  : Sets the ADO Database connection to MSAccess and
'                creates a ADO Database command object to accept
'                (sql queries, etc)
'=======================================================================
    Public Property Set Build(ByRef aBuild)
        Dim DBString
        Set mBuild = aBuild 

	DBString = mBuild.ProductChoice & "db1.mdb"   
        mBuild.FSO.CopyFile "E:\accessDB\db1.mdb", "E:\accessDB\" & DBString, True           
       'Set database path depending which machine it's on
        If mBuild.Shell.RegRead("HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows NT\CurrentVersion\RegisteredOwner") = "Alan Chou" Then
            mConnection.ConnectionString = "driver={Microsoft Access Driver (*.mdb)};DBQ=I:\Alan\db1.mdb"
        Else
            mConnection.ConnectionString = "driver={Microsoft Access Driver (*.mdb)};DBQ=E:\accessDB\" & DBString
        End If
        mConnection.Open
        Set mCmdTemp = wscript.CreateObject("ADODB.Command")
        mCmdTemp.ActiveConnection = mConnection
               
    End Property

	'Changes 000023 ==> 23
    Function StripLeadingZeros(aNumber)
  	 Dim result, length
  	 length = Len(aNumber)
  	 result = InStr(Left(aNumber, 1), "0")
  	 Do While (result <> 0 And length <> 1) 'strip off leading 0's one by one
   	    aNumber = Right(aNumber, length - 1)
   	    length = Len(aNumber)
   	    result = InStr(Left(aNumber, 1), "0")
 	  Loop
   
  	 StripLeadingZeros = aNumber
    End Function


    'used to limit the number of entries into the database. Restricted to startlabel and above.
    Function CheckLabelBounds(aLabel)
	Dim versionNum, bCheck, startLabel
	bCheck = False
	If(InStr(aLabel, mBuild.VersionPrefix) <> 0) Then
		versionNum = StripLeadingZeros(Replace(Right(aLabel, 6), """", ""))
		If(IsNumeric(versionNum) <> False) Then
			startLabel = StripLeadingZeros(Right(mBuild.StartLabel, 6))
			If(CInt(versionNum) >= CInt(startLabel)) Then
				bCheck = True
			End If
		End If
	End If	
	CheckLabelBounds = bCheck
	
    End Function
   
    
    '       Populate the Access DataBase Tables based on comma delimited text files generated by MKS
    '       Only use selected fields, there are many other fields and a couple other tables.
     Function PopulateTable(tableName, filePath, pjName, archIDOffset)
                Dim recordSet, archIDStr
                Dim words(15)

                If tableName = "txs" Then
                        inputFile = filePath & "\" & pjName & ".txs"
                Else
                        If tableName = "txm" Then
                                inputFile = filePath & "\" & pjName & ".txm"
                        Else
                                inputFile = filePath & "\" & pjName & ".txr"
                        End If
                End If
                'Open file
                Set readFile = mBuild.FSO.OpenTextFile(inputFile)

                'The input text file is comma delimited
                Pattern = ","
                Line = readFile.ReadLine        'Throw out the first line, because the first line has the header info

                Do While Not readFile.AtEndOfStream
                        Line = readFile.ReadLine
                        numWords = 0
                        startPos = 1
                        endPos = 1
                        'Read each of the words into a different position in the words array
                        Do While endPos <> 0
                                If numWords = 8 And tableName = "txr" Then
                                        endPos = Len(Line) + 1
                                Else
                                        endPos = InStr(startPos, Line, Pattern)
                                End If
                                If endPos = 0 Then
                                        words(numWords) = Mid(Line, startPos, Len(Line))
                                Else
                                        words(numWords) = Mid(Line, startPos, endPos - startPos)
                                End If
                                numWords = numWords + 1
                                startPos = endPos + 2
                        Loop

                        'Insert the words just read into the tables
                  
                        If words(0) <> "" Then
                                If tableName = "txs" Then
                                        words(1) = mBuild.InsertZeros(words(1))  'Insert 0's into the revision number
                              		If(CheckLabelBounds(words(2)) Or mBuild.VersionPrefix = "SolimarLicensing") Then
										    archIDStr = CStr(CInt(words(0)) + archIDOffset)
        	                                mCmdTemp.CommandText = "INSERT INTO " + tableName + " (ArchId, RevNum, Symbol) VALUES ('"
                	                        mCmdTemp.CommandText = mCmdTemp.CommandText + archIDStr + "','" + words(1) + "','" + words(2) + "')"
											mCmdTemp.Execute
									End If
                                Else
                                        If tableName = "txm" Then
                                                words(3) = mBuild.InsertZeros(words(3))  'Insert 0's into the revision number
                                                archIDStr = CStr(CInt(words(4)) + archIDOffset)
                                                mCmdTemp.CommandText = "INSERT INTO " + tableName + " (ArchId, ArchiveName, Head) VALUES ('"
                                                mCmdTemp.CommandText = mCmdTemp.CommandText + archIDStr + "','" + words(1) + "','" + words(3) + "')"
                                                'Keep track of the largest archID
                                                If mLargestArchSoFar < CInt(archIDStr) Then
                                                        mLargestArchSoFar = CInt(archIDStr)
                                                End If
                                        Else ' "txr"
                                                words(1) = mBuild.InsertZeros(words(1))  'Insert 0's into the revision number
                                                archIDStr = CStr(CInt(words(0)) + archIDOffset)
                                                words(8) = mBuild.ChopSingleQuote(words(8))  ' Chop single quotes from description
                                                mCmdTemp.CommandText = "INSERT INTO " + tableName + " (ArchId, RevNum, Author, LogMsg) VALUES ('"
                                                mCmdTemp.CommandText = mCmdTemp.CommandText + archIDStr + "','" + words(1) + "','" + words(3) + "','" + words(8) + "')"
                                        End If
					mCmdTemp.Execute
                                End If
				
                        End If
                Loop
                readFile.Close
    End Function

     'Clear out the current table to repopulate later
    Function DeleteTable(tableName)
                mCmdTemp.CommandText = "DELETE * FROM " + tableName
                mBuild.WriteToDlgAndFile "DELETE * FROM " + tableName
                mCmdTemp.Execute
    End Function
    
    Function ShowTable(tableName)
                mCmdTemp.CommandText = "Select * From " + tableName
                Set recordSet = mCmdTemp.Execute
                Do While Not recordSet.EOF
                        If InStr(tableName, "txs") <> 0 Then
                                mBuild.WriteToDlgAndFile recordSet.Fields("ArchId") + ", " + recordSet.Fields("RevNum") + ", " + recordSet.Fields("Symbol")
                        Else
                                If tableName = "txm" Then
                                        mBuild.WriteToDlgAndFile recordSet.Fields("ArchId") + ",  " + recordSet.Fields("ArchiveName") + ",  " + recordSet.Fields("Head")
                                Else ' "txr"
                                        mBuild.WriteToDlgAndFile recordSet.Fields("ArchId") + ",  " + recordSet.Fields("RevNum") + ",  " + recordSet.Fields("LogMsg")
                                End If
                        End If
                        recordSet.MoveNext
                Loop
                'connection.Close
    End Function
    
          '       Creates a Report Grouping Labels associated with paramLabel.
    Function CreateTextFileLicenseLabels(paramLabel, fileName)   'paramLabel = version of licensing 
																 'fileName = text file to write to.
                Dim RevNum, CurRevNum, archID, ArchiveName, LogMsg, tempLog, lastLog, Symbol
                If mBuild.FSO.FileExists(fileName) = True Then
                        mBuild.FSO.DeleteFile fileName, 1
                End If
                LabelReportName = fileName
                
				'select from txs where archid = txm_archid, revnum = txm_revnum
                mCmdTemp.CommandText = "Select * From txm"
                Set recordSetTXM = mCmdTemp.Execute
		'Reference file used to determine what license version was associated w/a product
		'3 choices - LicenseViewer.msi, SolimarLicenseManager.msi, SolimarLicenseServer.msi
		'All products that use solimar licensing have one of the 3.
                Do While Not recordSetTXM.EOF  
					ArchiveName = recordSetTXM.Fields("ArchiveName")     
					If InStr(ArchiveName, "SolimarLicenseServer.msi") > 0 Then
						archId = recordSetTXM.Fields("ArchId")
						Exit Do
					End If
					recordSetTXM.MoveNext
				Loop		'table with 1 entry which has the solimarlicensing.sln 
		
                mCmdTemp.CommandText = "Select * From txs Where ArchId = '" + archId + "'" 
				'create table with entries where they all have archId that are the same as the 
				'solimarlicensing.sln									   	
                Set recordSetTXS = mCmdTemp.Execute                
				Do While Not recordSetTXS.EOF
					Symbol = recordSetTXS.Fields("Symbol")
					If (InStr(Symbol,paramLabel) > 0) Then
						RevNum = recordSetTXS.Fields("RevNum")
						Exit Do
					End If
					recordSetTXS.MoveNext
				Loop		
  			    mCmdTemp.CommandText = "Select * From txs Where ArchId = '" + archId  + "'" + _		
							           " AND RevNum = '" + RevNum + "'" + _
							           " ORDER BY Symbol DESC"
               
				Set outputReport = mCmdTemp.Execute
				Set writeFile = mBuild.FSO.CreateTextFile(mBuild.mReportPath & "\Reports\" & fileName)
                
                Do While Not outputReport.EOF		'write to file each label on one line
                        Symbol = outputReport.Fields("Symbol")
                        If InStr(Symbol, "SolimarLicensing") = 0 Then
							writeFile.writeLine Symbol
						End If
                        outputReport.MoveNext
                Loop
                writeFile.Close
    End Function
  
      '       Creates a Report Grouping files by different Label that have changed since paramLabel
    Function CreateTextFileLabel(paramLabel, fileName)
                Dim RevNum, CurRevNum, archID, ArchiveName, LogMsg, tempLog, lastLog
                If mBuild.FSO.FileExists(fileName) = True Then
                        mBuild.FSO.DeleteFile fileName, 1
                End If
                LabelReportName = fileName

                'Delete from table
                'Clear out the current table to repopulate later
                mCmdTemp.CommandText = "DELETE * FROM outputReport"
                mCmdTemp.Execute
                mCmdTemp.CommandText = "Select * From txs Where Symbol = '" + Chr(34) + paramLabel + Chr(34) + "'"
                Set recordSetTXS = mCmdTemp.Execute
                Do While Not recordSetTXS.EOF
                        RevNum = recordSetTXS.Fields("RevNum")  'revNumber of the label you are comparing against
                        archID = recordSetTXS.Fields("ArchId")
                        mCmdTemp.CommandText = "SELECT DISTINCT txm.ArchiveName, txs.RevNum, txs.Symbol, txs.ArchId, txm.ArchId, txm.Head"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " FROM txs INNER JOIN txm ON txs.ArchId = txm.ArchId"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " WHERE '" + RevNum + "'<=txs.RevNum AND '" + archID + "' = txm.ArchId"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " AND '" + RevNum + "' < txm.Head"
                        Set recordSetTXM = mCmdTemp.Execute
                        Do While Not recordSetTXM.EOF
                                CurRevNum = recordSetTXM.Fields("RevNum")
                                'checkAndUpdateDialog revNum + " " + curRevNum + " " + recordSetTXm.Fields("Head")
                                If RevNum < CurRevNum And CurRevNum <= recordSetTXM.Fields("Head") Then
                                        If (mBuild.Project = 0 And Len(CurRevNum) = 9) Or mBuild.Project = 1 Then  'mBuild.Project=0=mainDevPath, 9 is the length w/o variant dev
                                                tempLog = recordSetTXM.Fields("Symbol")
                                                ArchiveName = recordSetTXM.Fields("ArchiveName")
                                                'checkAndUpdateDialog archiveName & " " & curRevNum & " " & tempLog
                                                'writefile.WriteLine archiveName & " " & curRevNum & " " & tempLogeMail
                                                mCmdTemp.CommandText = "INSERT INTO outputReport (ArchiveName, RevNum, LogMsg) VALUES ('"
                                                mCmdTemp.CommandText = mCmdTemp.CommandText + ArchiveName + "','" + CurRevNum + "','" + tempLog + "')"
                                                mCmdTemp.Execute
                                        End If
                                End If
                                recordSetTXM.MoveNext
                        Loop
                        recordSetTXS.MoveNext
                Loop

                Set writeFile = mBuild.FSO.CreateTextFile(mBuild.mReportPath & "\Reports\" & fileName)
                writeFile.writeLine "Looking at changes since label " + paramLabel
                mCmdTemp.CommandText = "Select * From outputReport"
                mCmdTemp.CommandText = mCmdTemp.CommandText + " ORDER BY LogMsg"
                Set recordSetReport = mCmdTemp.Execute
                lastLog = ""
                
                Do While Not recordSetReport.EOF
                        tempLog = recordSetReport.Fields("LogMsg")
                        If tempLog = lastLog Then
                                If Right(recordSetReport.Fields("RevNum"), 5) <> "0001""" Then
                                    writeFile.writeLine "         " & recordSetReport.Fields("ArchiveName") & " " & recordSetReport.Fields("RevNum")
                                End If
                        Else
                                writeFile.writeLine "----------------------------------------------------------------------------------------"
                                 If Right(recordSetReport.Fields("RevNum"), 5) <> "0001""" Then
                                    writeFile.writeLine tempLog
                                    writeFile.writeLine "         " & recordSetReport.Fields("ArchiveName") & " " & recordSetReport.Fields("RevNum")
                                    lastLog = tempLog
                                End If
                        End If
                        recordSetReport.MoveNext
                Loop
                writeFile.writeLine "----------------------------------------------------------------------------------------"
                writeFile.Close
        End Function

        '       Creates a Report Grouping files by different Description that have changed since paramLabel
        Function CreateTextFileDesc(paramLabel, fileName)
               Dim RevNum, CurRevNum, archID, ArchiveName, LogMsg, tempLog, lastLog
               If mBuild.FSO.FileExists(fileName) = True Then
                        mBuild.FSO.DeleteFile fileName, 1
                End If
                DescReportName = fileName
                
                'Delete from table
                'Clear out the current table to repopulate later
                mCmdTemp.CommandText = "DELETE * FROM outputReport"
                mCmdTemp.Execute

                mCmdTemp.CommandText = "Select * From txs Where Symbol = '" + Chr(34) + paramLabel + Chr(34) + "'"
                Set recordSetTXS = mCmdTemp.Execute
                Do While Not recordSetTXS.EOF
                        RevNum = recordSetTXS.Fields("RevNum")  'revNumber of the label you are comparing against
                        archID = recordSetTXS.Fields("ArchId")
                        mCmdTemp.CommandText = "SELECT DISTINCT txm.ArchiveName, txr.RevNum, txr.LogMsg, txr.ArchId, txr.Author, txm.ArchId, txm.Head"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " FROM txr INNER JOIN txm ON txr.ArchId = txm.ArchId"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " WHERE '" + RevNum + "'<=txr.RevNum AND '" + archID + "' = txr.ArchId"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " AND '" + RevNum + "' < txm.Head"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " AND txr.LogMsg <> '" + Chr(34) + Chr(34) + "'"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " AND txr.LogMsg <> '" + Chr(34) + "Initial revision" + Chr(34) + "'"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " AND txr.LogMsg <> '" + Chr(34) + "Duplicate Revision " + Chr(34) + "'"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " ORDER BY txr.LogMsg"
                        Set recordSetTXR = mCmdTemp.Execute
                        Do While Not recordSetTXR.EOF
                                CurRevNum = recordSetTXR.Fields("RevNum")
                                If RevNum < CurRevNum And CurRevNum <= recordSetTXR.Fields("Head") Then
                                        If (mBuild.Project = 0 And Len(CurRevNum) = 9) Or mBuild.Project = 1 Then  'mBuild.Project=0=mainDevPath, 9 is the length w/o variant dev
                                                tempLog = recordSetTXR.Fields("LogMsg")
                                                ArchiveName = recordSetTXR.Fields("ArchiveName")
                                                authorName = recordSetTXR.Fields("Author")
                                                mCmdTemp.CommandText = "INSERT INTO outputReport (ArchiveName, RevNum, Author, LogMsg) VALUES ('"
                                                mCmdTemp.CommandText = mCmdTemp.CommandText + ArchiveName + "','" + CurRevNum + "','" + authorName + "','" + tempLog + "')"
                                                mCmdTemp.Execute
                                        End If
                                End If
                                recordSetTXR.MoveNext
                        Loop
                        recordSetTXS.MoveNext
                Loop

                Set writeFile = mBuild.FSO.CreateTextFile(mBuild.mReportPath & "\Reports\" & fileName) 'Erin added - Make sure this is correct
                writeFile.writeLine "Looking at changes since label " + paramLabel
                mCmdTemp.CommandText = "Select * From outputReport"
                mCmdTemp.CommandText = mCmdTemp.CommandText + " ORDER BY LogMsg"
                Set recordSetReport = mCmdTemp.Execute
                lastLog = ""
                
                Do While Not recordSetReport.EOF
                        tempLog = recordSetReport.Fields("LogMsg")
                        If tempLog = lastLog Then       'Repeat of the log mesg
                             If Right(recordSetReport.Fields("RevNum"), 5) <> "0001""" Then
                                writeFile.writeLine "         " & recordSetReport.Fields("ArchiveName") & " " & recordSetReport.Fields("RevNum")
                             End If
                        Else
                                ' New log mesg,
                             If Right(recordSetReport.Fields("RevNum"), 5) <> "0001""" Then
                                writeFile.writeLine "----------------------------------------------------------------------------------------"
                             
                                writeFile.writeLine tempLog & "     " & recordSetReport.Fields("Author")
                                writeFile.writeLine "         " & recordSetReport.Fields("ArchiveName") & " " & recordSetReport.Fields("RevNum")
                                lastLog = tempLog
                             End If
                        End If
                        recordSetReport.MoveNext
                Loop
                writeFile.writeLine "----------------------------------------------------------------------------------------"
                writeFile.Close
        End Function

        'Creates a text file of all the differences from version to version
        Function CreateAllReleaseDesc(fileName)
                If mBuild.FSO.FileExists(fileName) = True Then
                        mBuild.FSO.DeleteFile fileName, 1
                End If
                
                currentVersion = "4.04a"
                Set readFile = mBuild.FSO.OpenTextFile(mBuild.mReportPath & "\release.txt")
                Set writeFile = mBuild.FSO.CreateTextFile(fileName)
                nextVersion = readFile.ReadLine
                Do While nextVersion <> currentVersion
                        nextVersion = readFile.ReadLine
                Loop
                
                Do While Not readFile.AtEndOfStream
                        'Delete from table
                        'Clear out the current table to repopulate later
                        mCmdTemp.CommandText = "DELETE * FROM outputReport"
                        mCmdTemp.Execute

                        currentVersion = nextVersion
                        nextVersion = readFile.ReadLine

                        'Get the lower bound
                        mCmdTemp.CommandText = "Select * From txs Where Symbol = '" + Chr(34) + currentVersion + Chr(34) + "'"
                        Set recordSetTXS = mCmdTemp.Execute

                        Do While Not recordSetTXS.EOF
                                RevNum = recordSetTXS.Fields("RevNum")  'lower revNumber of the label you are comparing against
                                archID = recordSetTXS.Fields("ArchId")

                                'Get the upper bound
                                mCmdTemp.CommandText = "Select * From txs Where Symbol = '" + Chr(34) + nextVersion + Chr(34) + "'"
                                mCmdTemp.CommandText = mCmdTemp.CommandText + " AND '" + archID + "' = txs.ArchId"
                                Set recordSetUpper = mCmdTemp.Execute
                                If Not recordSetUpper.EOF Then
                                        upperRevNum = recordSetUpper.Fields("RevNum")  'upper revNumber of the label you are comparing against

                                        mCmdTemp.CommandText = "SELECT DISTINCT txm.ArchiveName, txr.RevNum, txr.LogMsg, txr.ArchId, txr.Author, txm.ArchId, txm.Head"
                                        mCmdTemp.CommandText = mCmdTemp.CommandText + " FROM txr INNER JOIN txm ON txr.ArchId = txm.ArchId"
                                        mCmdTemp.CommandText = mCmdTemp.CommandText + " WHERE '" + RevNum + "'<=txr.RevNum AND ' + archID + ' = txr.ArchId"
                                        mCmdTemp.CommandText = mCmdTemp.CommandText + " AND txr.RevNum < '" + upperRevNum + "'"
                                        mCmdTemp.CommandText = mCmdTemp.CommandText + " AND txr.LogMsg <> '" + Chr(34) + Chr(34) + "'"
                                        mCmdTemp.CommandText = mCmdTemp.CommandText + " AND txr.LogMsg <> '" + Chr(34) + "Initial revision" + Chr(34) + "'"
                                        mCmdTemp.CommandText = mCmdTemp.CommandText + " AND txr.LogMsg <> '" + Chr(34) + "Duplicate Revision " + Chr(34) + "'"
                                        mCmdTemp.CommandText = mCmdTemp.CommandText + " ORDER BY txr.LogMsg"
                                        Set recordSetTXR = mCmdTemp.Execute
                                        Do While Not recordSetTXR.EOF
                                                CurRevNum = recordSetTXR.Fields("RevNum")
                                                If RevNum < CurRevNum And CurRevNum <= upperRevNum Then
                                                        If (mBuild.Project = 0 And Len(CurRevNum) = 9) Or mBuild.Project = 1 Then  'mBuild.Project=0=mainDevPath, 9 is the length w/o variant dev
                                                                tempLog = recordSetTXR.Fields("LogMsg")
                                                                ArchiveName = recordSetTXR.Fields("ArchiveName")
                                                                authorName = recordSetTXR.Fields("Author")
                                                                mCmdTemp.CommandText = "INSERT INTO outputReport (ArchiveName, RevNum, Author, LogMsg) VALUES ('"
                                                                mCmdTemp.CommandText = mCmdTemp.CommandText & ArchiveName & "','" & CurRevNum & "','" & authorName & "','" & tempLog & "')"
                                                                mCmdTemp.Execute
                                                        End If
                                                End If
                                                recordSetTXR.MoveNext
                                        Loop
                                End If
                                recordSetTXS.MoveNext
                        Loop

                        writeFile.writeLine "****************************************************************************************"
                        writeFile.writeLine "Looking at from " & currentVersion & " to " & nextVersion
                        writeFile.writeLine "****************************************************************************************"
                        mCmdTemp.CommandText = "Select * From outputReport"
                        mCmdTemp.CommandText = mCmdTemp.CommandText + " ORDER BY LogMsg"
                        Set recordSetReport = mCmdTemp.Execute
                        lastLog = ""
                
                        Do While Not recordSetReport.EOF
                                tempLog = recordSetReport.Fields("LogMsg")
                               
                                  If tempLog = lastLog Then       'Repeat of the log mesg
                                       If (Right(recordSetReport.Fields("RevNum"), 5) <> "0001""") Then
                                          writeFile.writeLine "         " & recordSetReport.Fields("ArchiveName") & " " & recordSetReport.Fields("RevNum")
                                       End If
                                  Else                                            ' New log mesg,
                                       If (Right(recordSetReport.Fields("RevNum"), 5) <> "0001""") Then
                                          writeFile.writeLine "----------------------------------------------------------------------------------------"
                                          writeFile.writeLine tempLog & "     " & recordSetReport.Fields("Author")
                                          writeFile.writeLine "         " & recordSetReport.Fields("ArchiveName") & " " & recordSetReport.Fields("RevNum")
                                          lastLog = tempLog
                                       End If
                                  End If
                                  recordSetReport.MoveNext
                        Loop
                        writeFile.writeLine "----------------------------------------------------------------------------------------"
                Loop
                readFile.Close
                writeFile.Close
        End Function

  Function CreateRevNumReport(paramLabel, fileName)
    Dim RevNum, CurRevNum, archID, ArchiveName, LogMsg, tempLog, lastLog
    Dim decimalPos, curPos, count, decimals
    mCmdTemp.CommandText = "DELETE * FROM outputReport"
    mCmdTemp.Execute
  
    mCmdTemp.CommandText = "SELECT ArchId, RevNum FROM txs WHERE Symbol = '" + Chr(34) + paramLabel + Chr(34) + "'"
    Set LabelTable = mCmdTemp.Execute
    
    If mBuild.Project = 0 Then
           decimals = 1  'RevNum format x.x
    Else
           decimals = 3    'RevNum format x.x.x.x
    End If
    
    Do While Not LabelTable.EOF
        archID = LabelTable.Fields("ArchId")
        LabelRevNum = LabelTable.Fields("RevNum")
        decimalPos = 1
        count = 0
        curPos = 1
        Do While decimalPos <> 0
            decimalPos = InStr(curPos, LabelRevNum, ".", vbTextCompare)
            If decimalPos <> 0 Then
               count = count + 1
            End If
               curPos = decimalPos + 1
        Loop
        If decimals <> count Then
                mCmdTemp.CommandText = "SELECT txr.LogMsg, txr.Author, txm.ArchiveName, txr.RevNum " + _
                                       "FROM txm INNER JOIN txr ON txm.ArchId = txr.ArchId " + _
                                       "WHERE txm.ArchId = '" + archID + "' AND " + _
                                       "txr.LogMsg <> '" + Chr(34) + Chr(34) + "' AND " + _
                                       "txr.LogMsg <> '" + Chr(34) + "Initial revision" + Chr(34) + "' AND " + _
                                       "txr.LogMsg <> '" + Chr(34) + "build" + Chr(34) + "' AND " + _
                                       "txr.LogMsg <> '" + Chr(34) + "Duplicate Revision " + Chr(34) + "'"
                Set ResultsTable = mCmdTemp.Execute
                Do While Not ResultsTable.EOF
                    LogMsg = ResultsTable.Fields("LogMsg")
                    Author = ResultsTable.Fields("Author")
                    filePath = ResultsTable.Fields("ArchiveName")
                    LogMsgRevNum = ResultsTable.Fields("RevNum")
                    If (LogMsgRevNum = LabelRevNum) Then
                         mCmdTemp.CommandText = "INSERT INTO outputReport (LogMsg, Author, ArchiveName, RevNum) VALUES (' " + _
                                                 LogMsg + "','" + Author + "','" + filePath + "','" + LogMsgRevNum + "')"
                         mCmdTemp.Execute
                    End If
                    ResultsTable.MoveNext
                Loop
        End If
        LabelTable.MoveNext
    Loop
    
    mCmdTemp.CommandText = "SELECT * FROM outputReport " + _
                           "ORDER BY LogMsg"
    Set FinalResultsTable = mCmdTemp.Execute
        
    If mBuild.FSO.FileExists(fileName) = True Then
        mBuild.FSO.DeleteFile fileName, 1
    End If
    DescReportName = fileName
      
    Set writeFile = mBuild.FSO.CreateTextFile(mBuild.mReportPath & "\Reports\" & fileName)
        
    Dim PrevLogMsg
    Dim test
    Do While Not FinalResultsTable.EOF
        RevNum = FinalResultsTable.Fields("RevNum")
        CurLogMsg = FinalResultsTable.Fields("LogMsg")
        Author = FinalResultsTable.Fields("Author")
        filePath = FinalResultsTable.Fields("ArchiveName")
        If (PrevLogMsg <> CurLogMsg) Then
            writeFile.writeLine "--------------------------------------------------------------------------------"
            writeFile.writeLine CurLogMsg & "      " & Author
            PrevLogMsg = CurLogMsg
        End If
        test = Right(RevNum, 5)
        writeFile.writeLine "        " + filePath + "      " + RevNum
        FinalResultsTable.MoveNext
    Loop
    
    writeFile.Close
      'connect.Close
  End Function

  Function CreateDescReportLabelToLabel(aStartLabel, aEndLabel, fileName)
    Dim RevNum, CurRevNum, archID, ArchiveName, LogMsg, tempLog, lastLog, LogMsgRevNum
    mCmdTemp.CommandText = "DELETE * FROM outputReport"
    mCmdTemp.Execute
     
    ' table with unique archid and revision number where all have the start label    
    mCmdTemp.CommandText = "SELECT ArchId, RevNum FROM txs WHERE Symbol = '" + Chr(34) + aStartLabel  + Chr(34) + "'"
    Set StartLabelTable = mCmdTemp.Execute
    Do While Not StartLabelTable.EOF
        archID = StartLabelTable.Fields("ArchId")    
        StartLabelRevNum = StartLabelTable.Fields("RevNum")
        
        'table with revision number where each entry has the specified unique archID and endlabel
        mCmdTemp.CommandText = "SELECT RevNum FROM txs " + _
                               "WHERE ArchId = '" + archID + "' AND " + _
                               "Symbol = '" + Chr(34) + aEndLabel + Chr(34) + "'"
        Set EndLabelTable = mCmdTemp.Execute
        
        Do While Not EndLabelTable.EOF 'There should be only 1 result in the table
            EndLabelRevNum = EndLabelTable.Fields("RevNum")
            If EndLabelRevNum > StartLabelRevNum Then
                mCmdTemp.CommandText = "SELECT txr.LogMsg, txr.Author, txm.ArchiveName, txr.RevNum " + _
                                       "FROM txm INNER JOIN txr ON txm.ArchId = txr.ArchId " + _
                                       "WHERE txm.ArchId = '" + archID + "' AND " + _
                                       "txr.RevNum >  '" + StartLabelRevNum + "' AND " + _
                                       "txr.RevNum <= '" + EndLabelRevNum   + "' AND " + _
                                       "txr.LogMsg <> '" + Chr(34) + Chr(34) + "'  AND " + _
                                       "txr.LogMsg <> '" + Chr(34) + "Initial revision" + Chr(34) + "' AND " + _
                                       "txr.LogMsg <> '" + Chr(34) + "build" + Chr(34) + "' AND " + _
                                       "txr.LogMsg <> '" + Chr(34) + "Duplicate Revision " + Chr(34) + "'"                       
                'results table that has all the end label revisions that are greater then the start label revision number
                Set ResultsTable = mCmdTemp.Execute
                Do While Not ResultsTable.EOF
                    LogMsg = ResultsTable.Fields("LogMsg")
                    Author = ResultsTable.Fields("Author")
                    filePath = ResultsTable.Fields("ArchiveName")
                    LogMsgRevNum = ResultsTable.Fields("RevNum")
                    'If ((mBuild.Project = 0 And Len(LogMsgRevNum) = 9) Or mBuild.Project = 1) Then
        
                         mCmdTemp.CommandText = "INSERT INTO outputReport (LogMsg, Author, ArchiveName, RevNum) VALUES (' " + _
                                                 LogMsg + "','" + Author + "','" + filePath + "','" + LogMsgRevNum + "')"
                         mCmdTemp.Execute
                    'End If
                    ResultsTable.MoveNext
                Loop
            End If
            EndLabelTable.MoveNext
        Loop
        StartLabelTable.MoveNext
    Loop
    
    mCmdTemp.CommandText = "SELECT * FROM outputReport " + _
                           "ORDER BY LogMsg"
    Set FinalResultsTable = mCmdTemp.Execute
        
    If mBuild.FSO.FileExists(fileName) = True Then
        mBuild.FSO.DeleteFile fileName, 1
    End If
    DescReportName = fileName
      
    Set writeFile = mBuild.FSO.CreateTextFile(mBuild.mReportPath & "\Reports\" & fileName)
        writeFile.writeLine "Looking at changes from " + aStartLabel + " to " + aEndLabel
    
    Dim PrevLogMsg
    Dim test
    Do While Not FinalResultsTable.EOF
        RevNum = FinalResultsTable.Fields("RevNum")
        CurLogMsg = FinalResultsTable.Fields("LogMsg")
        Author = FinalResultsTable.Fields("Author")
        filePath = FinalResultsTable.Fields("ArchiveName")
        If (PrevLogMsg <> CurLogMsg) Then
            writeFile.writeLine "--------------------------------------------------------------------------------"
            writeFile.writeLine CurLogMsg & "      " & Author
            PrevLogMsg = CurLogMsg
        End If
        test = Right(RevNum, 5)
        If Right(RevNum, 5) <> "0001""" Then
            writeFile.writeLine "        " + filePath + "      " + RevNum
        End If
        FinalResultsTable.MoveNext
    Loop
    
    writeFile.Close
  End Function


  Function CreateLabelReportLabelToLabel(aStartLabel, aEndLabel, fileName)
    Dim RevNum, CurRevNum, archID, ArchiveName, LogMsg, tempLog, lastLog
    mCmdTemp.CommandText = "DELETE * FROM outputReport"
    mCmdTemp.Execute
    
    mCmdTemp.CommandText = "SELECT ArchId, Symbol, RevNum FROM txs WHERE Symbol = '" + Chr(34) + aStartLabel  + Chr(34) + "'"
    Set StartLabelTable = mCmdTemp.Execute
        
    Do While Not StartLabelTable.EOF
        archID = StartLabelTable.Fields("ArchId")
              
        StartLabelRevNum = StartLabelTable.Fields("RevNum")
        StartSymbol = StartLabelTable.Fields("Symbol")
       
        mCmdTemp.CommandText = "SELECT RevNum, Symbol FROM txs " + _
                               "WHERE ArchId = '" + archID + "' AND " + _
                               "Symbol = '" + Chr(34) + aEndLabel + Chr(34) + "'"
        Set EndLabelTable = mCmdTemp.Execute
        
        Do While Not EndLabelTable.EOF 'There should be only 1 result in the table
            EndLabelRevNum = EndLabelTable.Fields("RevNum")
            EndSymbol = EndLabelTable.Fields("Symbol")

            If EndLabelRevNum > StartLabelRevNum Then
                 mCmdTemp.CommandText = "SELECT txm.ArchiveName, txs.Symbol, txs.RevNum " + _
                                         "FROM txm INNER JOIN txs ON txm.ArchId = txs.ArchId " + _
                                         "WHERE txm.ArchId = '" + archID + "' AND " + _ 
                                         "txs.RevNum > '" + StartLabelRevNum + "' AND " + _
                                         "txs.RevNum <= '" + EndLabelRevNum + "'"
                 Set ResultsTable = mCmdTemp.Execute
                Do While Not ResultsTable.EOF
                    Label = ResultsTable.Fields("Symbol")
                    filePath = ResultsTable.Fields("ArchiveName")
                    RevNum = ResultsTable.Fields("RevNum")
                    'If ((RevNum > StartLabelRevNum) And (RevNum <= EndLabelRevNum)) And _
                    'If ((mBuild.Project = 0 And Len(RevNum) = 9) Or mBuild.Project = 1) Then
                       mCmdTemp.CommandText = "INSERT INTO outputReport (LogMsg, ArchiveName, RevNum) VALUES (' " + _
                                               Label + "','" + filePath + "','" + RevNum + "')"
                       mCmdTemp.Execute
                    'End If
                    ResultsTable.MoveNext
                Loop
            End If
            EndLabelTable.MoveNext
        Loop
        StartLabelTable.MoveNext
    Loop
    mCmdTemp.CommandText = "SELECT * FROM outputReport " + _
                           "ORDER BY LogMsg"
    Set FinalResultsTable = mCmdTemp.Execute
    
    If mBuild.FSO.FileExists(fileName) = True Then
        mBuild.FSO.DeleteFile fileName, 1
    End If
    LabelReportName = fileName
      
    Set writeFile = mBuild.FSO.CreateTextFile(mBuild.mReportPath & "\Reports\" & fileName)
    writeFile.writeLine "Looking at changes from " + aStartLabel + " to " + aEndLabel
    
    Dim PrevLabel
    Do While Not FinalResultsTable.EOF
        RevNum = FinalResultsTable.Fields("RevNum")
        CurLabel = FinalResultsTable.Fields("LogMsg")
        filePath = FinalResultsTable.Fields("ArchiveName")
        If (PrevLabel <> CurLabel) Then
            writeFile.writeLine "--------------------------------------------------------------------------------"
            writeFile.writeLine CurLabel
            PrevLabel = CurLabel
        End If
        If Right(RevNum, 5) <> "0001""" Then
            writeFile.writeLine "        " + filePath + "      " + RevNum
        End If
        FinalResultsTable.MoveNext
    Loop
    
    writeFile.Close
    'connect.Close
   End Function

