<!-- 
	ModuleInclude optional attributes:
	
	default			integer		(default: 0)
					A default module is one that gets licensed by default when moving a key from 
					a trial state to a permanent state. The value specified in default is the number
					of licenses that this module recieves when moving to a permanent state.
					
	licenseRead		string		(default: '')
					For modules that have special interpretation of the value stored on the key, this 
					attribute defines a function that maps the value on the key to a number of licenses.
					(This function should be the inverse of licenseWrite)
					
					The syntax of this string is the code in a C language function with the following 
					prototype:	long LicenseReadFunction(const long value);
					
					So a function that multiplies the number on the key by 100 is modelled by the 
					following function:
					
					unsigned int LicenseReadFunction(const unsigned int value)
					{
						return (value * 100);
					}
					
					the string specified for licenseRead would be the string 'value * 100'		
					
					A module that makes use of this is the 'Concurrent Users' of SOLSearcher.
					Special case: Empty string indicates the identity function.
					
	licenseWrite	string		(default: '')
					For modules that have special interpretation of the value stored on the key, this 
					attribute defines a function that maps a number of licenses to a value on the key.
					(This function should be the inverse of licenseWrite)
					
					The syntax of this string is the code in a C language function with the following 
					prototype:	unsigned int LicenseWriteFunction(const unsigned int value);
					
					So a function that divides the number of licenses by 100 is modelled by the 
					following function:
					
					unsigned int LicenseWriteFunction(const unsigned int value)
					{
						return (value / 100);
					}
					
					the string specified for licenseRead would be the string 'value / 100'
					
					A module that makes use of this is the 'Concurrent Users' of SOLSearcher.
					Special case: Empty string indicates the identity function.
				
	isLicense		true | false	(default: true)
					Determines whether a module is interpreted as a license count or an arbitrary integer 
					to be interpreted by the client. Most modules are license counts, so most (if not all)
					modules will have isLicense set to true.
				
	unlimited		integer		(default: 0)
					An unlimited module license is a license that can be obtained an infinite number of 
					times. This attribute specifies the minimum number of licenses at which a license 
					becomes an unlimited license. For instance, if unlimited="10" is specified, and the key 
					specifies 9 as the number of licenses, then up to 9 licenses can be obtained at once.
					If the key specifies 10, the license satisfies the unlimited threshold and is then 
					treated as an unlimited license, and thus an infinite number of licenses can be obtained.
					Special case: 0 indicates that the module license is never treated as infinite.
					
	isPool			true | false	(default: false)
					A pooled module is one that shares a set of licenses with one or more modules.
					If isPool is true on a module, this indicates that this module serves as the storage space
					for the shared license. Any modules participating in the pool will use the 'pool' attribute
					to indicate that they participate in this pool, and the participating module's storage
					specification (offset,bits) indicate then whether that module is enabled or not.
					
	pool			integer	(default: 0)
					A pooled module is one that shares a set of licenses with one or more modules. This value
					indicates the id of a Pool to associate this module with.
					Special case: 0 indicates that a module is not a pooled license module.
-->


<KeyFormat>
	<!--	offset is measured in bits (decimal or hex) from address 0 on the key, and bits is the size of the field in bits -->
	<KeyStorage bits="1096">
		<KeyStorageRegion type="serial" offset="0x000" bits="32"/>
		<KeyStorageRegion type="inaccessible" offset="0x020" bits="96"/>
		<KeyStorageRegion type="module" offset="0x080" bits="288"/>
		<KeyStorageRegion type="header" offset="0x1A0" bits="224"/>
		<KeyStorageRegion type="module" offset="0x280" bits="16"/>
		<KeyStorageRegion type="header" offset="0x290" bits="112"/>		
		<KeyStorageRegion type="module" offset="0x300" bits="64"/>
		<KeyStorageRegion type="header" offset="0x340" bits="192"/>
	</KeyStorage>
	<KeyHeader>
		<HeaderField id="10000" offset="0x000" bits="16" name="Serial Number"/>
		<HeaderField id="10001" offset="0x010" bits="16" name="Developer ID"/>
		<HeaderField id="10002"	offset="0x1A0" bits="16" name="Initial Counter"/>
		<HeaderField id="10003"	offset="0x1B0" bits="16" name="Extended Counter"/>
		<HeaderField id="10004"	offset="0x1C0" bits="32" name="Primary Descriptor" default="0x9AAB6B01"/>
		<HeaderField id="10005"	offset="0x1E0" bits="32" name="Primary Password" default="0x1A00FED1"/>
		<HeaderField id="10006"	offset="0x200" bits="32" name="Expiration Date"/>
		<HeaderField id="10007"	offset="0x2A0" bits="32" name="Secondary Descriptor" default="0xBF0A1143"/>
		<!-- We may need to move this field if it's in the way of counter/algorithm cells -->
		<HeaderField id="10030" offset="0x340" bits="16" name="Key Host"/>
		<HeaderField id="10020"	offset="0x380" bits="16" name="Key Type"/>
		<HeaderField id="10021"	offset="0x390" bits="16" name="Product ID"/>
		<HeaderField id="10022"	offset="0x3A0" bits="16" name="Product Version"/>
		<HeaderField id="10023"	offset="0x3B0" bits="16" name="Key Version"/>
		<HeaderField id="10024"	offset="0x3C0" bits="16" name="Uses"/>
		<HeaderField id="10025"	offset="0x3D0" bits="16" name="Status"/>
		<HeaderField id="10026"	offset="0x3E0" bits="16" name="Customer Number"/>
		<HeaderField id="10027"	offset="0x3F0" bits="16" name="Key Number"/>
	</KeyHeader>
