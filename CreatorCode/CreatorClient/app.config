      </setting>
      <setting name="ServerList" serializeAs="Xml">
        <value>
          <ArrayOfString xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xmlns:xsd="http://www.w3.org/2001/XMLSchema">
            <string>localhost</string>
          </ArrayOfString>
        </value>
      </setting>
    </Client.Creator.Properties.Settings>
  </userSettings>
</configuration>